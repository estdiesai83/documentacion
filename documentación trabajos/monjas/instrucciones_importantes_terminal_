Para instalar lo de los colorines::

# Update
sudo apt-get update
# Install packages
sudo apt-get install htop bat vim git cmake fzf automake libtool libtool-bin
# Install LSD from source
wget https://github.com/Peltoche/lsd/releases/download/0.23.1/lsd_0.23.1_arm64.deb &&
sudo dpkg -i lsd_0.23.1_arm64.deb &&
rm lsd_0.23.1_arm64.deb &&
# Install neovim
git clone https://github.com/neovim/neovim &&
cd neovim &&
git checkout stable &&
make CMAKE_BUILD_TYPE=release &&
sudo make install &&
# Install nvchad
git clone https://github.com/NvChad/NvChad ~/.config/nvim --depth 1 &&
nvim
# ZSH
sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
# PowerLevel10K
git clone --depth=1 https://github.com/romkatv/powerlevel10k.git ~/powerlevel10k
echo 'source ~/powerlevel10k/powerlevel10k.zsh-theme' >>~/.zshrc
